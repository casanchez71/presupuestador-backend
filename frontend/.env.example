VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_API_URL=/api

# Auth guard — set to "true" to require login. Omit or set to "false" for demo mode.
# When false/unset, the backend DEMO_ORG_ID env var is used to bypass auth.
VITE_AUTH_ENABLED=false
